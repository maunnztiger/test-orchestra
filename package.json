{
  "name": "test-orchestra",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "testorchestra": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "test": "playwright test",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "login": "ts-node -r tsconfig-paths/register src/index.ts run scenarios/ --tags Login",
    "filters": "ts-node -r tsconfig-paths/register src/index.ts run scenarios/ --tags Filters",
    "login_results_db": "npm run login -- --report db",
    "login_results_json": "npm run login -- --report json",
    "filters_result_json": "npm run filters -- --report json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.1",
    "@types/pg": "^8.18.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^17.4.0",
    "playwright": "^1.56.1",
    "prettier": "3.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.2.3",
    "js-yaml": "^4.1.0",
    "pg": "^8.20.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.1"
  },
  "description": "**Ein Open-Source-Projekt für die Zukunft von Testarchitektur und Software-Qualität.**",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maunnztiger/test-orchestra.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/maunnztiger/test-orchestra/issues"
  },
  "homepage": "https://github.com/maunnztiger/test-orchestra#readme"
}
